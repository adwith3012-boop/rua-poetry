generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Int
  image     String   // We will store base64 or URL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageContent {
  id              String   @id @default(cuid())
  heroEst         String
  heroTagline     String
  philosophyQuote String
  philosophyText  String
  updatedAt       DateTime @updatedAt
}
